<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.safefaces.safefaces.Javafx.Controller.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <TextField fx:id="nameField" prefHeight="3.0" prefWidth="118.0" promptText="Name" />
    <TextField fx:id="phoneField" promptText="PhoneNumber" />
    <Button onAction="#handleAddContact" text="Add contact" />
    <Button onAction="#handleContacts" text=" Contact list" />
    <Label fx:id="outputLabel" />
    <Button onAction="#openUserView" text="Open User View" />

</VBox>
