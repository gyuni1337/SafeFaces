<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.safefaces.safefaces.Controller.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TextField fx:id="nameField" promptText="Name"/>
    <TextField fx:id="phoneField" promptText="PhoneNumber"/>
    <Label fx:id="outputLabel"/>
    <Button text="Add contact" onAction="#handleAddContact"/>
    <Button text=" Contact list" onAction="#handleContacts"/>
    <Button text="Open User View" onAction="#openUserView"/>

</VBox>
