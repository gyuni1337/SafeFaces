<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="269.0" prefWidth="253.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.safefaces.safefaces.Controller.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <TextField fx:id="nameField" prefHeight="3.0" prefWidth="118.0" promptText="Name" />
    <TextField fx:id="phoneField" promptText="PhoneNumber" />
    <Label fx:id="outputLabel" />
    <Button onAction="#handleAddContact" text="Add contact" />
    <Button onAction="#handleContacts" text=" Contact list" />
</VBox>
